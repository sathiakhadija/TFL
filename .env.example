TFL_API_KEY=your-tfl-api-key-here
TFL_APP_ID=your-tfl-app-id-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tfl_pipeline
POSTGRES_USER=tfl_user
POSTGRES_PASSWORD=tfl_password
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://tfl_user:tfl_password@postgres:5432/tfl_pipeline
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here
DBT_PROFILES_DIR=/opt/airflow/dbt_project
